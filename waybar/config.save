{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 10,

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [ "custom/notification"
   "temperature",
    "backlight",
    "pulseaudio",
    "network",
    "battery",
     "custom/notification"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "all-outputs": true,
    "on-click": "activate",
    "format-icons": {
      "1": "ΎΕι",
      "2": "ΎΚσ",
      "3": "ΎΒ╝",
      "4": "≤░ΗΞ",
      "5": "ΎΑ╜",
      "6": "≤░ΟΗ",
      "default": "ΎΕΣ"
    }
  },

  "clock": {
    "format": "ΎΑΩ  {:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  },

  "network": {
    "format-wifi": "ΎΘτ  {essid}",
    "format-ethernet": "≤░ΙΑ  Wired",
    "format-disconnected": "ΎΒ▒  Disconnected",
    "tooltip": true,
    "on-click": "kitty -e nmtui"
  },

  "pulseaudio": {
    "format": "ΎΑρ  {volume}%",
    "format-muted": "≤░ΨΒ",
    "on-click": "pavucontrol"
  },

  "backlight": {
    "format": "ΎΔτ  {percent}%"
  },

  "temperature": {
    "thermal-zone": 0,
    "format": "ΎΜΚ  {temperatureC}┬░C",
    "critical-threshold": 85
  },

  "battery": {
    "format": "{icon}  {capacity}%",
    "format-charging": "ΎΔπ {icon}  {capacity}%",
    "format-plugged": "ΎΘο {icon}  {capacity}%",
    "format-full": "ΎΚΑ  {capacity}%",
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format-icons": [
      "ΎΚΕ",
      "ΎΚΔ",
      "ΎΚΓ",
      "ΎΚΒ",
      "ΎΚΑ"
    ]
  },

  "custom/notification": {
    "tooltip": true,
    "format": "<span size='16pt'>{icon}</span>",
    "format-icons": {
      "notification": "≤▒Ζτ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γι",
      "dnd-none": "≤░ςΥ",
      "inhibited-notification": "≤░Γδ",
      "inhibited-none": "≤░ςΣ",
      "dnd-inhibited-notification": "≤░Γδ",
      "dnd-inhibited-none": "≤░ςΣ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t",
    "on-click-right": "swaync-client -d",
    "escape": true
  }
}
